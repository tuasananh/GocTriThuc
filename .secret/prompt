```tsx
import { useLexicalComposerContext } from "@lexical/react/LexicalComposerContext"
import { useEffect, useRef } from "react"
import { toDocument } from "../serializer/toDocument"
import { fromDocument } from "../serializer/fromDocument"
import type { SerializedDocument } from "../types"

type Props = { initialDoc?: SerializedDocument; onInput: (doc: SerializedDocument) => void }

export function SerializationPlugin({ initialDoc, onInput }: Props) {
	const [editor] = useLexicalComposerContext()
	const seededRef = useRef(false)

	useEffect(() => {
		if (seededRef.current || !initialDoc) return
		seededRef.current = true
		editor.update(() => fromDocument(initialDoc))
	}, [editor, initialDoc])

	useEffect(() => {
		return editor.registerUpdateListener(({ editorState }) => {
			editorState.read(() => onInput(toDocument()))
		})
	}, [editor, onInput])

	return null
}
```

