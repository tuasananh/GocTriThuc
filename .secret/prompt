			{ type: "bulleted-list", text: "two" },
		])
	})
	it("keeps a code block", () => {
		const out = roundTrip({ version: 1, blocks: [{ id: "a", type: "code", text: "const x = 1", language: "ts" }] })
		expect(out.blocks[0].type).toBe("code")
		expect(out.blocks[0].text).toContain("const x = 1")
