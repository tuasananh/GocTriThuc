### `frontend/packages/lexical-editor/src/serializer/fromDocument.ts`

```tsx
import { $getRoot, $createParagraphNode, $createTextNode } from "lexical"
import { $createHeadingNode, $createQuoteNode, type HeadingTagType } from "@lexical/rich-text"
import { $createListNode, $createListItemNode } from "@lexical/list"
import { $createCodeNode } from "@lexical/code"
import type { RichSpan, SerializedBlock, SerializedDocument } from "../types"

function applyRich(target: { append: (n: any) => void }, rich?: RichSpan[], fallback?: string) {
	if (rich && rich.length > 0) {
		for (const span of rich) {
			const t = $createTextNode(span.text)
			let f = 0
			if (span.bold) f |= 1
			if (span.italic) f |= 2
			if (span.strikethrough) f |= 4
			if (span.underline) f |= 8
			if (span.code) f |= 16
			if (f) t.setFormat(f as any)
			target.append(t)
		}
	} else if (fallback) {
		target.append($createTextNode(fallback))
	}
}

function createBlock(b: SerializedBlock) {
	switch (b.type) {
		case "heading-1":
		case "heading-2":
		case "heading-3": {
			const tag = ("h" + b.type.slice(-1)) as HeadingTagType
			const h = $createHeadingNode(tag)
			applyRich(h, b.rich, b.text)
			return h
		}
		case "quote": {
			const q = $createQuoteNode()
			applyRich(q, b.rich, b.text)
			return q
		}
		case "code": {
			const c = $createCodeNode(b.language)
			if (b.text) c.append($createTextNode(b.text))
			return c
		}
		case "bulleted-list":
		case "numbered-list":
		case "check-list": {
			const type = b.type === "bulleted-list" ? "bullet" : b.type === "numbered-list" ? "number" : "check"
			const list = $createListNode(type)
			const item = $createListItemNode(b.type === "check-list" ? !!b.checked : undefined)
			applyRich(item, b.rich, b.text)
			list.append(item)
			return list
		}
		case "divider":
		case "paragraph":
		default: {
			const p = $createParagraphNode()
			applyRich(p, b.rich, b.text)
			return p
		}
	}
}

export function fromDocument(doc: SerializedDocument) {
	const root = $getRoot()
	root.clear()
	for (const b of doc.blocks) root.append(createBlock(b))
}
```

