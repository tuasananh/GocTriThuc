```tsx
import { $getRoot, $isParagraphNode, $isTextNode, type ElementNode, type LexicalNode, type TextNode } from "lexical"
import { $isHeadingNode, $isQuoteNode, type HeadingNode } from "@lexical/rich-text"
import { $isListNode, $isListItemNode, type ListNode, type ListItemNode } from "@lexical/list"
import { $isCodeNode, type CodeNode } from "@lexical/code"
import type { BlockType, RichSpan, SerializedBlock, SerializedDocument } from "../types"
import { newId } from "./ids"

function richFromTextNode(n: TextNode): RichSpan {
	const f = n.getFormat()
	return {
		text: n.getTextContent(),
		bold: (f & 1) !== 0,
		italic: (f & 2) !== 0,
		strikethrough: (f & 4) !== 0,
		underline: (f & 8) !== 0,
		code: (f & 16) !== 0,
	}
}

function richFromElement(node: ElementNode): RichSpan[] {
	const out: RichSpan[] = []
	for (const child of node.getChildren()) {
		if ($isTextNode(child)) out.push(richFromTextNode(child))
		else if ("getTextContent" in child) out.push({ text: (child as LexicalNode).getTextContent() })
	}
	return out
}

function headingType(n: HeadingNode): BlockType {
	const tag = n.getTag()
	if (tag === "h1") return "heading-1"
	if (tag === "h2") return "heading-2"
	return "heading-3"
}

function listType(n: ListNode): BlockType {
	switch (n.getListType()) {
		case "bullet": return "bulleted-list"
		case "number": return "numbered-list"
		case "check":  return "check-list"
		default:       return "bulleted-list"
	}
}

function listItemToBlock(item: ListItemNode, type: BlockType): SerializedBlock {
	return {
		id: newId(),
		type,
		text: item.getTextContent(),
		rich: richFromElement(item),
		checked: type === "check-list" ? item.getChecked() ?? false : undefined,
	}
}

function nodeToBlocks(node: LexicalNode): SerializedBlock[] {
	if ($isHeadingNode(node)) return [{ id: newId(), type: headingType(node), text: node.getTextContent(), rich: richFromElement(node) }]
	if ($isQuoteNode(node))   return [{ id: newId(), type: "quote", text: node.getTextContent(), rich: richFromElement(node) }]
	if ($isCodeNode(node)) {
		const c = node as CodeNode
		return [{ id: newId(), type: "code", text: c.getTextContent(), language: c.getLanguage() ?? undefined }]
	}
	if ($isListNode(node)) {
		const t = listType(node)
		const out: SerializedBlock[] = []
		for (const child of node.getChildren()) {
			if ($isListItemNode(child)) out.push(listItemToBlock(child, t))
		}
		return out
	}
	if ($isParagraphNode(node)) return [{ id: newId(), type: "paragraph", text: node.getTextContent(), rich: richFromElement(node) }]
	if ("getTextContent" in node) return [{ id: newId(), type: "paragraph", text: (node as LexicalNode).getTextContent() }]
	return []
}

export function toDocument(): SerializedDocument {
	const blocks: SerializedBlock[] = []
	for (const node of $getRoot().getChildren()) blocks.push(...nodeToBlocks(node))
	return { version: 1, blocks }
}
