```tsx
import "@app/lexical-editor" // side-effect: registers <notion-editor>
import type { SerializedDocument } from "@app/lexical-editor"
import { useEffect, useRef } from "react"

declare global {
	namespace JSX {
		interface IntrinsicElements {
			"notion-editor": React.DetailedHTMLProps<React.HTMLAttributes<HTMLElement>, HTMLElement>
		}
	}
}

export type { SerializedDocument } from "@app/lexical-editor"

type Props = {
	value?: SerializedDocument
	onChange?: (doc: SerializedDocument) => void
}

export function NotionEditor({ value, onChange }: Props) {
	const ref = useRef<HTMLElement & { value: SerializedDocument | null }>(null)

	useEffect(() => {
		if (ref.current && value !== undefined) ref.current.value = value ?? null
	}, [value])

	useEffect(() => {
		const el = ref.current
		if (!el || !onChange) return
		const h = (e: Event) => onChange((e as CustomEvent<{ doc: SerializedDocument }>).detail.doc)
		el.addEventListener("editor-change", h)
		return () => el.removeEventListener("editor-change", h)
	}, [onChange])

	return <notion-editor ref={ref as any} />
}
```

