### `frontend/packages/lexical-editor/src/element/NotionEditorElement.ts`

```tsx
import { createRoot, type Root } from "react-dom/client"
import { createElement } from "react"
import { EditorRoot } from "../ui/EditorRoot"
import themeCss from "../ui/theme.css?inline"
import playgroundCss from "../playground-vendor/themes/PlaygroundEditorTheme.css?inline"
import type { SerializedDocument } from "../types"

export class NotionEditorElement extends HTMLElement {
	private root: Root | null = null
	private currentDoc: SerializedDocument | null = null
	private debounceTimer: number | null = null

	get value(): SerializedDocument | null { return this.currentDoc }
	set value(doc: SerializedDocument | null) {
		this.currentDoc = doc
		this.render()
	}

	connectedCallback() {
		const shadow = this.attachShadow({ mode: "open" })
		const style = document.createElement("style")
		style.textContent = playgroundCss + "\n" + themeCss
		shadow.appendChild(style)
		const mount = document.createElement("div")
		shadow.appendChild(mount)
		this.root = createRoot(mount)
		this.render()
		queueMicrotask(() => this.dispatchEvent(new CustomEvent("editor-ready")))
	}

	disconnectedCallback() {
		if (this.debounceTimer) clearTimeout(this.debounceTimer)
		this.root?.unmount()
		this.root = null
	}

	private render() {
		if (!this.root) return
		this.root.render(
			createElement(EditorRoot, {
				initialDoc: this.currentDoc ?? undefined,
				onInput: (doc) => {
					this.currentDoc = doc
					this.dispatchEvent(new CustomEvent("editor-input", { detail: { doc } }))
					if (this.debounceTimer) clearTimeout(this.debounceTimer)
					this.debounceTimer = window.setTimeout(() => {
						this.dispatchEvent(new CustomEvent("editor-change", { detail: { doc } }))
					}, 400)
				},
			}),
		)
	}
}
