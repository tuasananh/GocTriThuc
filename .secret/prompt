import { describe, it, expect } from "vitest"
import { createHeadlessEditor } from "@lexical/headless"
import { fromDocument } from "../src/serializer/fromDocument"
import { toDocument } from "../src/serializer/toDocument"
import type { SerializedDocument } from "../src/types"
import PlaygroundNodes from "../src/playground-vendor/nodes/PlaygroundNodes"

function roundTrip(input: SerializedDocument): SerializedDocument {
	const editor = createHeadlessEditor({
		namespace: "test",
		nodes: [...PlaygroundNodes],
		onError: (e) => { throw e },
	})
	editor.update(() => fromDocument(input), { discrete: true })
	let out: SerializedDocument = { version: 1, blocks: [] }
	editor.getEditorState().read(() => { out = toDocument() })
	return out
}

function stripIds(d: SerializedDocument) { return d.blocks.map((b) => ({ type: b.type, text: b.text })) }

describe("serializer round-trip", () => {
	it("keeps paragraph text", () => {
		const out = roundTrip({ version: 1, blocks: [{ id: "a", type: "paragraph", text: "hello" }] })
